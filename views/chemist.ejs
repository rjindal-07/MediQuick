<!DOCTYPE html>
<html>
<head>
    <title>Chemist Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h2>Orders in <%= area %></h2>
    <div class="row">
        <% orders.forEach(order => { %>
            <div class="col-md-4 mb-3">
                <div class="card p-3 shadow-sm">
                    <h6>Order #<%= order.id %> [<%= order.area %>]</h6>
                    <% if (order.area !== area) { %> <span class="badge bg-danger">BACKUP REQUEST</span> <% } %>
                    <p><%= order.medicine %> (<%= order.mg %>) - ₹<%= order.price %></p>
                    <a href="/uploads/<%= order.file %>" target="_blank" class="btn btn-link btn-sm">View Prescription</a>
                    <form action="/update-status/<%= order.id %>" method="POST">
                        <input type="text" name="reason" class="form-control mb-2" placeholder="Reason (if rejecting)">
                        <div class="d-flex gap-2">
                            <button name="status" value="Accepted" class="btn btn-success btn-sm w-100">Accept</button>
                            <button name="status" value="Rejected" class="btn btn-danger btn-sm w-100">Reject</button>
                        </div>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
    <a href="/logout" class="btn btn-secondary mt-3">Logout</a>
</body>
</html>