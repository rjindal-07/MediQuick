<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Orders | MediQuick</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light py-5">

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">My Order History</h3>
        <a href="/" class="btn btn-primary btn-sm">Back to Store</a>
    </div>

    <% if (orders.length === 0) { %>
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <p class="text-muted">You haven't placed any orders yet.</p>
            <a href="/" class="btn btn-outline-primary">Order Medicines Now</a>
        </div>
    <% } %>

    <div class="row">
        <% orders.forEach(o => { %>
            <div class="col-md-6 mb-4">
                <div class="card border-0 shadow-sm border-start border-4 border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-3 align-items-start">
                            <div>
                                <span class="fw-bold text-dark">Order ID: #<%= o.id %></span>
                                <div class="text-muted small">Placed on: <%= o.date %></div>
                            </div>
                            <span class="badge bg-success">SUCCESSFUL</span>
                        </div>
                        
                        <div class="bg-light p-2 rounded mb-3">
                            <ul class="list-unstyled mb-0 small">
                                <% o.items.forEach(item => { %> 
                                    <li class="d-flex justify-content-between mb-1">
                                        <span><%= item.medicineName %> (x<%= item.qty %>)</span>
                                        <span class="text-muted">₹<%= (item.price * item.qty).toFixed(2) %></span>
                                    </li>
                                <% }) %>
                            </ul>
                        </div>

                        <div class="d-flex justify-content-between fw-bold h6">
                            <span>Total Paid</span>
                            <span class="text-primary">₹<%= o.total %></span>
                        </div>
                        <div class="mt-2 pt-2 border-top">
                            <small class="text-muted d-block">Paid via: <strong><%= o.method %></strong></small>
                            <small class="text-muted d-block">Transaction Ref: <%= o.paymentId %></small>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

</body>
</html>